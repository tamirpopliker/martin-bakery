# Test credentials for RLS test suite. Copy this file to .env.test.local and fill in.
# .env.test.local is gitignored (matches *.local pattern).

# Supabase project — same as the app uses
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Test admin: role='admin', branch_id=NULL
TEST_ADMIN_USERNAME=test-admin
TEST_ADMIN_PASSWORD=

# Test factory: role='factory', branch_id=NULL
TEST_FACTORY_USERNAME=test-factory
TEST_FACTORY_PASSWORD=

# Test branch: role='branch', branch_id=1 (אברהם אבינו)
TEST_BRANCH_USERNAME=test-branch
TEST_BRANCH_PASSWORD=
TEST_BRANCH_ID=1
